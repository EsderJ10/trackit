{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "paths": {
      "@/core/*": [
        "./src/core/*"
      ],
      "@/modules/*": [
        "./src/modules/*"
      ],
      "@/ui/*": [
        "./src/ui/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ]
}
